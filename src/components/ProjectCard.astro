---
export interface Props {
  title: string;
  subtitle?: string;
  description: string;
  achievements: string[];
  tags: string[];
  screenshots?: string[];
  video?: string;
}

const { title, subtitle, description, achievements, tags, screenshots, video } = Astro.props as Props;
const hasGui = (screenshots && screenshots.length > 0) || Boolean(video);
---

<div class="single-item">
  <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 8px;">
    <h3 style="margin: 0;">{title}</h3>
    {hasGui && (
      <button
        type="button"
        class="gui-trigger"
        data-gui-trigger
        data-gui-title={title}
        style="display: inline-flex; align-items: center; gap: 6px; background: #1c1c1c; border: 1px solid #333; color: #fff; padding: 6px 14px; border-radius: 6px; font-size: 13px; cursor: pointer; transition: background 0.2s; flex-shrink: 0;"
        onmouseover="this.style.background='#2b2b2b'"
        onmouseout="this.style.background='#1c1c1c'"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
          <rect x="3" y="3" width="18" height="18" rx="2" />
          <circle cx="8.5" cy="8.5" r="1.5" />
          <path d="M21 15l-5-5L5 21" />
        </svg>
        View GUI
      </button>
    )}
  </div>

  {subtitle && <div style="margin-top: 6px; color: #a8a8a8; font-size: 14px;">{subtitle}</div>}

  <div class="project-desc project-desc-list" style="margin-top: 10px; margin-left: 0;">
    <div style="margin-left: 0;">{description}</div>
  </div>

  <div class="mini-label-white" style="margin-top: 18px;">Core Technical Achievements</div>
  <div class="project-desc project-desc-list" style="margin-top: 6px; margin-left: -24px;">
    <ul role="list">
      {achievements.map((a) => <li>{a}</li>)}
    </ul>
  </div>

  {tags?.length ? (
    <>
      <div class="mini-label-white" style="margin-top: 18px;">Tech Tags</div>
      <div class="chips-container">
        {tags.map((t) => <div class="single-chip">{t}</div>)}
      </div>
    </>
  ) : null}

  {hasGui && (
    <template data-gui-media>
      {screenshots && screenshots.map(src => <img src={src} alt={`${title} screenshot`} loading="lazy" />)}
      {video && <video src={video} controls muted playsinline preload="metadata"></video>}
    </template>
  )}
</div>