---
import ProjectCard from './ProjectCard.astro';

const projects = [
  {
    title: 'EQtinue ang Heritage AR Karaoke – Song 1 (Kung Ikaw ay Masaya)',
    subtitle: 'Legacy Logic Optimization & Text Animation Refinement',
    description:
      'Refactored and optimized an in-progress AR interactive karaoke filter in Effect House to improve performance and code maintainability.',
    achievements: [
      'Cleaned up and refactored the visual scripting/logic flow for regular text rendering, synchronized real-time highlighted lyrics, and bouncing-ball text tracking.',
      'Programmed and integrated a dynamic “win animation” sequence triggered upon song completion.',
    ],
    tags: ['Effect House', 'Visual Scripting', 'Refactoring', 'AR Animation'],
  },
  {
    title: 'EQtinue ang Heritage AR Karaoke – Song 2 (Bahay Kubo)',
    subtitle: 'Real-Time Audio DSP & Advanced Gameplay Mechanics',
    description:
      'Developed an advanced, independent iteration of the karaoke system in Effect House incorporating custom audio processing and physics-based tracking.',
    achievements: [
      'Engineered a real-time Karaoke scoring framework integrating pitch detection and timing window mechanics to validate user vocal inputs within Effect House.',
      'Optimized filter performance and minimized memory overhead by implementing custom Object Pooling logic.',
      'Simulated complex asset velocity shifts aligned with the music’s rhythm using a custom “Transit by Time” logic flow to bypass traditional physics constraints.',
      'Refined the UI layer to match custom aesthetic requirements, incorporating interactive “hovering vegetables” animations.',
    ],
    tags: ['Effect House', 'Pitch Detection', 'Audio DSP', 'Object Pooling', 'UI/UX Animation', 'Visual Scripting'],
  },
  {
    title: 'Catch the Healthy Food Challenge',
    subtitle: 'Full-Stack Gamified AR Filter Architecture',
    description:
      'Architected and built a custom, highly optimized interactive catching game from scratch within Effect House utilizing mouth-tracking triggers.',
    achievements: [
      'Built a robust game loop featuring localized face-tracking interaction, active game timers, and a real-time scoring system.',
      'Maximized mobile AR efficiency and bypassed Effect House performance bottlenecks by utilizing Object Pooling paired with dynamic runtime texture swapping (recycling existing game objects instead of instantiating new assets).',
      'Programmed a “Healthy Streak” combo system that scales visual effects based on continuous correct inputs and resets upon junk-food collision.',
      'Integrated a responsive visual/audio feedback loop, featuring glowing ambient screen pulses (Green/Red), contextual pop-up text alerts, and synchronized eating SFX.',
    ],
    tags: ['Effect House', 'Face Tracking', 'Game Loop', 'Object Pooling', 'Audio Feedback', 'Visual Scripting'],
  },
];
---

<section>
  {projects.map((p) => (
    <ProjectCard
      title={p.title}
      subtitle={p.subtitle}
      description={p.description}
      achievements={p.achievements}
      tags={p.tags}
    />
  ))}
</section>
