---
import Layout from '../layouts/Layout.astro';
import Project from "../components/Project.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title="Skills | Lance Atendido" selectedItem="skills">
          <div class="back-nav-container">
            <a href={`${base}/`} class="back-nav-button w-inline-block">
              <img src={`${base}/assets/back.svg`} loading="lazy" alt="" class="back-nav-img" />
              <div>Back</div>
            </a>
          </div>
          <div class="content-container">
            <h1>Skills</h1>

            <section class="items-container">
              <div class="single-item">
                <h3 style="margin: 0;">Programming Languages</h3>
                <div class="project-desc project-desc-list" style="margin-top: 12px;">
                  <ul role="list">
                    <li>I write backend and application logic primarily in C#, PHP, and Python</li>
                    <li>I build cross-platform mobile apps using Dart and Flutter</li>
                    <li>I use JavaScript, HTML, and CSS for front-end and web scripting needs</li>
                  </ul>
                </div>
                <div class="mini-label-white" style="margin-top: 14px;">Technologies & tools</div>
                <div class="chips-container">
                  <div class="single-chip">Python</div>
                  <div class="single-chip">C#</div>
                  <div class="single-chip">C++</div>
                  <div class="single-chip">PHP</div>
                  <div class="single-chip">Dart</div>
                  <div class="single-chip">HTML</div>
                  <div class="single-chip">JavaScript</div>
                  <div class="single-chip">CSS</div>
                </div>
              </div>
            </section>

            <section class="items-container">
              <div class="single-item">
                <h3 style="margin: 0;">Backend Development</h3>
                <div class="project-desc project-desc-list" style="margin-top: 12px;">
                  <ul role="list">
                    <li>I design and build REST APIs and full CRUD systems for real applications</li>
                    <li>I implement authentication, encrypted storage, and secure client-server data transfer</li>
                    <li>I structure and parse JSON data for communication between mobile, web, and backend layers</li>
                  </ul>
                </div>
                <div class="mini-label-white" style="margin-top: 14px;">Technologies & tools</div>
                <div class="chips-container">
                  <div class="single-chip">REST API</div>
                  <div class="single-chip">CRUD Operations</div>
                  <div class="single-chip">JSON</div>
                  <div class="single-chip">Client–Server Communication</div>
                  <div class="single-chip">Authentication & Encryption</div>
                </div>
              </div>
            </section>

            <section class="items-container">
              <div class="single-item">
                <h3 style="margin: 0;">Database Management</h3>
                <div class="project-desc project-desc-list" style="margin-top: 12px;">
                  <ul role="list">
                    <li>I design relational database schemas with proper table relationships and normalization</li>
                    <li>I enforce data integrity using foreign keys, constraints, triggers, and stored procedures</li>
                    <li>I work across both MySQL and Oracle SQL environments</li>
                  </ul>
                </div>
                <div class="mini-label-white" style="margin-top: 14px;">Technologies & tools</div>
                <div class="chips-container">
                  <div class="single-chip">MySQL</div>
                  <div class="single-chip">Oracle SQL</div>
                  <div class="single-chip">Table Relationships & Normalization</div>
                  <div class="single-chip">Foreign Keys & Constraints</div>
                  <div class="single-chip">Triggers</div>
                  <div class="single-chip">Stored Procedures</div>
                </div>
              </div>
            </section>

            <section class="items-container">
              <div class="single-item">
                <h3 style="margin: 0;">Frameworks & Platforms</h3>
                <div class="project-desc project-desc-list" style="margin-top: 12px;">
                  <ul role="list">
                    <li>I build cross-platform mobile applications using Flutter</li>
                    <li>I build web applications using React and Node.js</li>
                  </ul>
                </div>
                <div class="mini-label-white" style="margin-top: 14px;">Technologies & tools</div>
                <div class="chips-container">
                  <div class="single-chip">Flutter</div>
                  <div class="single-chip">React</div>
                  <div class="single-chip">Node.js</div>
                </div>
              </div>
            </section>

            <section class="items-container">
              <div class="single-item">
                <h3 style="margin: 0;">Tools & Others</h3>
                <div class="project-desc project-desc-list" style="margin-top: 12px;">
                  <ul role="list">
                    <li>I use Git and GitHub for version control and collaborative development</li>
                    <li>I use Visual Studio and VS Code as my primary development environments</li>
                    <li>I use XAMPP for local PHP and MySQL development and testing</li>
                  </ul>
                </div>
                <div class="mini-label-white" style="margin-top: 14px;">Technologies & tools</div>
                <div class="chips-container">
                  <div class="single-chip">GitHub</div>
                  <div class="single-chip">Git</div>
                  <div class="single-chip">Visual Studio</div>
                  <div class="single-chip">VS Code</div>
                  <div class="single-chip">XAMPP</div>
                </div>
              </div>
            </section>
          </div>
        </div>
</Layout>
