---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title="Achievements | Lance Atendido" selectedItem="achievements">
          <div class="back-nav-container">
            <a href={`${base}/`} class="back-nav-button w-inline-block">
              <img src={`${base}/assets/back.svg`} loading="lazy" alt="" class="back-nav-img" />
              <div>Back</div>
            </a>
          </div>
          <div class="content-container">
            <h1>Achievements & Certifications</h1>

            <section class="items-container">
              <h3>Honors</h3>
              <div class="resouce-items" style="margin-top: 16px; gap: 0;">
                <div class="single-item">
                  <div class="achievement-eyebrow">Honor</div>
                  <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 8px; margin-bottom: 6px;">
                    <h4 style="color: #fff; margin: 0;">Hackathon 1st Place — ConnectMe</h4>
                    <a
                      href="https://github.com/MemDbg/connectme"
                      target="_blank"
                      rel="noopener noreferrer"
                      style="display: inline-flex; align-items: center; gap: 6px; background: #1c1c1c; border: 1px solid #333; color: #fff; padding: 6px 14px; border-radius: 6px; font-size: 13px; text-decoration: none; transition: background 0.2s; flex-shrink: 0;"
                      onmouseover="this.style.background='#2b2b2b'"
                      onmouseout="this.style.background='#1c1c1c'"
                    >
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                      </svg>
                      View Code
                    </a>
                  </div>
                  <p class="project-desc">Awarded 1st place in a hackathon competition for developing ConnectMe, demonstrating applied software development skills under time-constrained conditions.</p>
                  <div class="chips-container" style="margin-top: 14px;">
                    <div class="single-chip small-chip">Hackathon 1st Place</div>
                  </div>
                </div>
                <div class="single-item">
                  <div class="achievement-eyebrow">Honor</div>
                  <h4 style="color: #fff; margin-bottom: 6px;">Dean's Lister</h4>
                  <p class="project-desc">Recognized as Dean's Lister for the 1st term across 1st to 3rd year at Mapúa Malayan Colleges Laguna (MMCL), maintaining consistent academic excellence in the BS Information Technology program.</p>
                  <div class="chips-container" style="margin-top: 14px;">
                    <div class="single-chip small-chip">Dean's Lister</div>
                  </div>
                </div>
              </div>
            </section>

            <section class="items-container">
              <h3>Certifications</h3>
              <div class="achievements-grid">
                <div class="single-item">
                  <div class="achievement-eyebrow">Certification</div>
                  <h4 style="color: #fff; margin-bottom: 6px;">TOEIC — 805/990</h4>
                  <p class="project-desc">Achieved a score of 805 out of 990 on the Test of English for International Communication (TOEIC), demonstrating strong professional English proficiency for workplace environments.</p>
                  <div class="chips-container" style="margin-top: 14px;">
                    <div class="single-chip small-chip">TOEIC 805/990</div>
                  </div>
                </div>
                <div class="single-item">
                  <div class="achievement-eyebrow">Certification</div>
                  <h4 style="color: #fff; margin-bottom: 6px;">CCNA: Introduction to Networks</h4>
                  <p class="project-desc">Foundational certification covering networking concepts, protocols, and infrastructure fundamentals.</p>
                  <div class="chips-container" style="margin-top: 14px;">
                    <div class="single-chip small-chip">CCNA</div>
                    <div class="single-chip small-chip">Network Security</div>
                  </div>
                </div>
                <div class="single-item">
                  <div class="achievement-eyebrow">Certification</div>
                  <h4 style="color: #fff; margin-bottom: 6px;">Ethical Hacking</h4>
                  <p class="project-desc">Certification covering cybersecurity principles, penetration testing methodologies, and ethical hacking techniques.</p>
                  <div class="chips-container" style="margin-top: 14px;">
                    <div class="single-chip small-chip">Ethical Hacking</div>
                  </div>
                </div>
                <div class="single-item">
                  <div class="achievement-eyebrow">Certification</div>
                  <h4 style="color: #fff; margin-bottom: 6px;">CompTIA Tech+ Series</h4>
                  <p class="project-desc">Industry-recognized certification validating foundational IT knowledge and technical support skills.</p>
                  <div class="chips-container" style="margin-top: 14px;">
                    <div class="single-chip small-chip">CompTIA Tech+</div>
                  </div>
                </div>
                <div class="single-item">
                  <div class="achievement-eyebrow">Certification</div>
                  <h4 style="color: #fff; margin-bottom: 6px;">Python Programming — CodeChum</h4>
                  <p class="project-desc">Certification demonstrating proficiency in Python programming fundamentals and applied problem-solving.</p>
                  <div class="chips-container" style="margin-top: 14px;">
                    <div class="single-chip small-chip">Python (CodeChum)</div>
                  </div>
                </div>
                <div class="single-item">
                  <div class="achievement-eyebrow">Certification</div>
                  <h4 style="color: #fff; margin-bottom: 6px;">Google Cloud Skill Boost</h4>
                  <p class="project-desc">Completed multiple Google Cloud learning paths covering Infrastructure, Security, Data, Machine Learning, and App Development.</p>
                  <div class="chips-container" style="margin-top: 14px;">
                    <div class="single-chip small-chip">Google Cloud</div>
                    <div class="single-chip small-chip">Machine Learning</div>
                  </div>
                </div>
                <div class="single-item">
                  <div class="achievement-eyebrow">Certification</div>
                  <h4 style="color: #fff; margin-bottom: 6px;">Full Stack Web Development — Amazon (Coursera)</h4>
                  <p class="project-desc">Amazon certification covering modern full-stack web development practices, earned through Coursera.</p>
                  <div class="chips-container" style="margin-top: 14px;">
                    <div class="single-chip small-chip">Full Stack Web Dev</div>
                  </div>
                </div>
                <div class="single-item" style="grid-column: 1 / -1;">
                  <div class="achievement-eyebrow">Certification</div>
                  <h4 style="color: #fff; margin-bottom: 6px;">Blockchain — Certificate of Participation</h4>
                  <p class="project-desc">Participated in a blockchain-focused program covering distributed ledger technology concepts and applications.</p>
                  <div class="chips-container" style="margin-top: 14px;">
                    <div class="single-chip small-chip">Blockchain</div>
                    <div class="single-chip small-chip">Cryptocurrency</div>
                  </div>
                </div>
              </div>
            </section>

          </div>
        </div>
</Layout>
