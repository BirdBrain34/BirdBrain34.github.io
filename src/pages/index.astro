---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Lance Atendido" selectedItem="home">
          <main class="fold-content-container">
            <div class="fold-content">
              <h1>Hi, I'm Lance.<br />I build things for software.</h1>
              <div
                style="margin-top: 14px; border: 1px solid rgba(255,255,255,0.10); background: rgba(15,16,20,0.60); border-radius: 16px; padding: 10px 12px; box-shadow: 0 0 0 1px rgba(255,255,255,0.03); width: fit-content;"
              >
                <p
                  class="lead"
                  style="margin: 0; text-align: justify; text-justify: inter-word;"
                >
                  IT student at MMCL specializing in backend development. Skilled in Python, C#, C++, Dart, REST APIs, and database systems. Passionate about building reliable, efficient software and eager to apply my skills through many projects.
                </p>
              </div>
            </div>
            <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
              <button
                type="button"
                data-gui-trigger
                data-gui-media="cv"
                data-gui-title="Curriculum Vitae"
                style="display: inline-flex; align-items: center; gap: 8px; background: #1c1c1c; border: 1px solid #333; color: #fff; padding: 10px 20px; border-radius: 8px; font-size: 15px; cursor: pointer; transition: background 0.2s;"
                onmouseover="this.style.background='#2b2b2b'"
                onmouseout="this.style.background='#1c1c1c'"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <polyline points="14 2 14 8 20 8" />
                  <line x1="16" y1="13" x2="8" y2="13" />
                  <line x1="16" y1="17" x2="8" y2="17" />
                  <polyline points="10 9 9 9 8 9" />
                </svg>
                View CV
              </button>
              <a
                href={`${base}/assets/CV/Atendido_CV.pdf`}
                download="Atendido_CV.pdf"
                style="display: inline-flex; align-items: center; gap: 8px; background: #1c1c1c; border: 1px solid #333; color: #fff; padding: 10px 20px; border-radius: 8px; font-size: 15px; cursor: pointer; text-decoration: none; transition: background 0.2s;"
                onmouseover="this.style.background='#2b2b2b'"
                onmouseout="this.style.background='#1c1c1c'"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                  <polyline points="7 10 12 15 17 10" />
                  <line x1="12" y1="15" x2="12" y2="3" />
                </svg>
                Download CV
              </a>
            </div>
            <template data-gui-media="cv">
              <img src={`${base}/assets/CV/Atendido_CV_page_1.png`} alt="CV page 1" loading="lazy" />
              <img src={`${base}/assets/CV/Atendido_CV_page_2.png`} alt="CV page 2" loading="lazy" />
            </template>
          </main>
          <div class="projects-section">
            <a href={`${base}/skills/`} class="projects-container">
              <div class="single-projects-category">
                <div class="projects-category-image-container">
                  <img src={`${base}/assets/skills-icon.png`} loading="lazy" alt="Skills" class="projects-category-image" />
                </div>
              </div>
              <div class="single-projects-content">
                <h4>Skills</h4>
                <div class="tech-tools-container">
                  <div class="mini-label-white gray-color">Technologies & tools</div>
                  <div class="chips-container chips-container-small-width">
                    <div class="single-chip small-chip">Programming Languages</div>
                    <div class="single-chip small-chip">Backend Development</div>
                    <div class="single-chip small-chip">Database Management</div>
                    <div class="single-chip small-chip">Frameworks & Platforms</div>
                    <div class="single-chip small-chip">Tools & Others</div>
                  </div>
                </div>
              </div>
            </a>
            <a href={`${base}/personal-projects/`} class="projects-container">
              <div class="single-projects-category">
                <div class="projects-category-image-container">
                  <img src={`${base}/assets/project-icon.png`} loading="lazy" alt="Projects" class="projects-category-image" style="filter: invert(1) brightness(2);" />
                </div>
              </div>
              <div class="single-projects-content">
                <h4>Projects</h4>
                <div class="tech-tools-container">
                  <div class="mini-label-white gray-color">Featured projects</div>
                  <div class="chips-container chips-container-small-width">
                    <div class="single-chip small-chip">SapPIIre</div>
                    <div class="single-chip small-chip">CCIS Tracker</div>
                    <div class="single-chip small-chip">PokedexCards</div>
                    <div class="single-chip small-chip">Personify API</div>
                    <div class="single-chip small-chip">DiceHard</div>
                  </div>
                </div>
              </div>
            </a>

            <a href={`${base}/experience/`} class="projects-container">
              <div class="single-projects-category">
                <div class="projects-category-image-container">
                  <img
                    src={`${base}/assets/experience.png`}
                    loading="lazy"
                    alt="Experience"
                    class="projects-category-image"
                  style="object-fit: contain; width: 100px; height: 100px; filter: invert(1) brightness(2);"
                  />
                </div>
              </div>
              <div class="single-projects-content">
                <h4>Experience</h4>
                <div class="tech-tools-container">
                  <div class="mini-label-white gray-color">OJT / Internship</div>
                  <div class="chips-container chips-container-small-width">
                    <div class="single-chip small-chip">PurpleBug Inc.</div>
                  </div>
                </div>
              </div>
            </a>

            <a href={`${base}/achievements/`} class="projects-container">
              <div class="single-projects-category">
                <div class="projects-category-image-container devops-img">
                  <img src={`${base}/assets/achievements-icon.png`} loading="lazy" alt="Achievements" class="projects-category-image" />
                </div>
              </div>
              <div class="single-projects-content">
                <h4>Achievements &&nbsp;Certifications</h4>
                <div class="tech-tools-container">
                  <div class="mini-label-white gray-color">Honors & certifications</div>
                  <div class="chips-container chips-container-small-width">
                    <div class="single-chip small-chip">Honors</div>
                    <div class="single-chip small-chip">Certifications</div>
                  </div>
                </div>
              </div>
            </a>

            <a href={`${base}/seminars/`} class="projects-container">
              <div class="single-projects-category">
                <div class="projects-category-image-container">
                  <img src={`${base}/assets/seminars-icon.png`} loading="lazy" alt="Seminars" class="projects-category-image" style="filter: invert(1) brightness(2);" />
                </div>
              </div>
              <div class="single-projects-content">
                <h4>Seminars</h4>
                <div class="tech-tools-container">
                  <div class="mini-label-white gray-color">Featured seminars</div>
                  <div class="chips-container chips-container-small-width">
                    <div class="single-chip small-chip">Crypto & Blockchain</div>
                    <div class="single-chip small-chip">IoT Security</div>
                    <div class="single-chip small-chip">AI in Social Media</div>
                    <div class="single-chip small-chip">Beyond the Breach</div>
                    <div class="single-chip small-chip">Beyond the Code</div>
                  </div>
                </div>
              </div>
            </a>
          </div>
        </div>
</Layout>
